{
  "name": "react-native-altcha",
  "version": "2.0.0",
  "description": "ALTCHA React Native widget supporting PoW v2",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "cd example && yarn start",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\" \"example/src/**/*.{js,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,ts,tsx}\" \"example/src/**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build"
  },
  "keywords": [
    "altcha",
    "react-native",
    "ios",
    "android",
    "captcha",
    "pow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altcha-org/altcha-react-native.git"
  },
  "author": "Daniel Regeci <536331+ovx@users.noreply.github.com> (https://altcha.org)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/altcha-org/altcha-react-native/issues"
  },
  "homepage": "https://github.com/altcha-org/altcha-react-native#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@evilmartians/lefthook": "^1.13.6",
    "@react-native/babel-preset": "0.78.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "babel-jest": "^30.3.0",
    "commitlint": "^19.8.1",
    "del-cli": "^5.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "expo": "~53.0.0",
    "expo-audio": "^0.4.9",
    "expo-localization": "~16.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-builder-bob": "^0.40.18",
    "react-native-svg": "^15.15.4",
    "react-test-renderer": "19.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "expo": ">=50",
    "expo-audio": ">=0.4.0",
    "expo-localization": ">=16.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-svg": ">=15"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo-localization|expo-audio|expo-modules-core|@expo/vector-icons|react-native|@react-native/js-polyfills|@react-native/virtualized-lists)/)"
    ],
    "moduleNameMapper": {
      "^react-native-svg$": "<rootDir>/src/__mocks__/react-native-svg.ts"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.52.0"
  }
}
